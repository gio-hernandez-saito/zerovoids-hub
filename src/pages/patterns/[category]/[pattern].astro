---
import Layout from '../../../layouts/Layout.astro';
import FrameworkTabs from '../../../components/FrameworkTabs.astro';
import CodeBox from '../../../components/CodeBox.astro';
import { patterns, categories } from '../../../data/patterns';
import fs from 'node:fs';
import path from 'node:path';
import { highlight } from '../../../utils/highlight';
import { marked } from 'marked';

// 동적 라우팅: 23개 패턴 각각에 대해 정적 경로 생성
export function getStaticPaths() {
  return patterns.map(p => ({
    params: { category: p.category, pattern: p.slug },
    props: { pattern: p },
  }));
}

const { pattern } = Astro.props;
const cat = categories.find(c => c.id === pattern.category)!;

// ── 파일 읽기 유틸 ──
const patternsRoot = path.resolve('content', 'design-patterns', 'patterns', pattern.category, pattern.slug);

function readFile(filePath: string): string | null {
  try {
    return fs.readFileSync(filePath, 'utf-8');
  } catch {
    return null;
  }
}

// ── README 읽기 ──
const readme = readFile(path.join(patternsRoot, 'README.md')) ?? '';

// Mermaid 다이어그램을 marked 처리 전에 플레이스홀더로 교체
// (marked가 Mermaid 구문을 HTML 이스케이프하거나 <pre><code>로 감싸는 것을 방지)
const mermaidBlocks: string[] = [];
const readmeWithPlaceholders = readme.replace(
  /```mermaid\n([\s\S]*?)```/g,
  (_match, code) => {
    mermaidBlocks.push(code.trim());
    return `MERMAIDBLOCK${mermaidBlocks.length - 1}END`;
  }
);

// README를 HTML로 변환 (h1 제목은 이미 헤더에 표시하므로 제거)
const readmeWithoutTitle = readmeWithPlaceholders.replace(/^# .+\n+/, '');
let readmeHtml = await marked.parse(readmeWithoutTitle);

// 플레이스홀더를 실제 Mermaid HTML로 교체 (marked 처리 후이므로 이스케이프 없음)
readmeHtml = readmeHtml.replace(
  /<p>MERMAIDBLOCK(\d+)END<\/p>/g,
  (_match, index) =>
    `<div class="mermaid-container"><pre class="mermaid">${mermaidBlocks[Number(index)]}</pre></div>`
);

// ── 소스 코드 읽기 ──
const tsFile = fs.readdirSync(path.join(patternsRoot, 'typescript'))
  .find(f => f.endsWith('.ts') && !f.endsWith('.test.ts'));
const tsCode = tsFile ? readFile(path.join(patternsRoot, 'typescript', tsFile)) : null;
const tsTestFile = fs.readdirSync(path.join(patternsRoot, 'typescript'))
  .find(f => f.endsWith('.test.ts'));
const tsTestCode = tsTestFile ? readFile(path.join(patternsRoot, 'typescript', tsTestFile)) : null;

// 프레임워크 코드 읽기
const fwCodeMap: Record<string, { file: string; code: string }> = {};
for (const fw of pattern.frameworks) {
  const fwDir = path.join(patternsRoot, fw);
  if (!fs.existsSync(fwDir)) continue;
  const files = fs.readdirSync(fwDir);
  const mainFile = files.find(f =>
    f === 'App.tsx' || f === 'App.vue' || f === 'App.svelte'
  );
  if (mainFile) {
    const code = readFile(path.join(fwDir, mainFile));
    if (code) fwCodeMap[fw] = { file: mainFile, code };
  }
}

// 하이라이트된 코드 준비 (싱글턴 하이라이터 사용)
const tsHighlighted = tsCode ? await highlight(tsCode, 'typescript') : '';
const tsTestHighlighted = tsTestCode ? await highlight(tsTestCode, 'typescript') : '';

// 프레임워크 탭 데이터 준비 (CodeBox용으로 filename, rawCode 포함)
const fwTabs = [];
if (tsCode && tsFile) {
  fwTabs.push({ id: 'typescript', label: 'TypeScript', filename: tsFile, code: tsHighlighted, rawCode: tsCode });
}
for (const fw of pattern.frameworks) {
  const entry = fwCodeMap[fw];
  if (!entry) continue;
  const lang = fw === 'react' ? 'tsx' : fw === 'vue' ? 'vue' : 'svelte';
  const label = fw === 'react' ? 'React' : fw === 'vue' ? 'Vue' : 'Svelte';
  fwTabs.push({
    id: fw,
    label,
    filename: entry.file,
    code: await highlight(entry.code, lang),
    rawCode: entry.code,
  });
}

// 패턴 간 네비게이션
const currentIndex = patterns.findIndex(p => p.slug === pattern.slug);
const prevPattern = currentIndex > 0 ? patterns[currentIndex - 1] : null;
const nextPattern = currentIndex < patterns.length - 1 ? patterns[currentIndex + 1] : null;
---

<Layout title={pattern.name} section="patterns">
  <div class="pattern-header">
    <span class="pattern-badge" style={`background: ${cat.color}20; color: ${cat.color}`}>
      {cat.name} · {cat.nameKo}
    </span>
    <h1>{pattern.name}</h1>
    <p class="pattern-desc">{pattern.description}</p>
    <div class="pattern-fw-badges">
      <span class="fw-badge ts">TypeScript</span>
      {pattern.frameworks.map(fw => (
        <span class={`fw-badge ${fw}`}>
          {fw === 'react' ? 'React' : fw === 'vue' ? 'Vue' : 'Svelte'}
        </span>
      ))}
    </div>
  </div>

  {/* README 콘텐츠 (테이블, 리스트, Mermaid 다이어그램 모두 인라인) */}
  <div class="markdown-body" set:html={readmeHtml} />

  {/* 코드 탭 */}
  {fwTabs.length > 0 && (
    <section class="section">
      <h2>구현 코드</h2>
      <FrameworkTabs tabs={fwTabs} />
    </section>
  )}

  {/* 테스트 코드 */}
  {tsTestHighlighted && tsTestCode && tsTestFile && (
    <section class="section">
      <h2>테스트 코드</h2>
      <CodeBox
        filename={tsTestFile}
        code={tsTestHighlighted}
        rawCode={tsTestCode}
      />
    </section>
  )}

  {/* 네비게이션 */}
  <nav class="pattern-nav">
    {prevPattern ? (
      <a href={`/patterns/${prevPattern.category}/${prevPattern.slug}/`} class="nav-link nav-prev">
        <span class="nav-dir">← 이전</span>
        <span class="nav-name">{prevPattern.name}</span>
      </a>
    ) : <div />}
    {nextPattern ? (
      <a href={`/patterns/${nextPattern.category}/${nextPattern.slug}/`} class="nav-link nav-next">
        <span class="nav-dir">다음 →</span>
        <span class="nav-name">{nextPattern.name}</span>
      </a>
    ) : <div />}
  </nav>
</Layout>

{/* Mermaid 렌더링 스크립트 */}
<script>
  async function initMermaid() {
    const elements = document.querySelectorAll('.mermaid');
    if (elements.length === 0) return;

    try {
      const mermaidModule = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
      mermaidModule.default.initialize({
        startOnLoad: false,
        theme: 'default',
        themeVariables: {
          fontSize: '14px',
          fontFamily: 'Inter, sans-serif',
        },
        securityLevel: 'loose',
      });
      await mermaidModule.default.run({ nodes: elements });
      // 렌더링 성공 시 컨테이너 표시
      document.querySelectorAll('.mermaid-container').forEach(el => {
        el.classList.add('rendered');
      });
    } catch (e) {
      // CDN 로드 실패 시 코드 텍스트라도 보여주기
      console.warn('Mermaid load failed:', e);
      document.querySelectorAll('.mermaid-container').forEach(el => {
        el.classList.add('fallback');
      });
    }
  }
  initMermaid();
</script>

<style>
  .pattern-header {
    margin-bottom: 2rem;
  }

  .pattern-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    margin-bottom: 0.75rem;
  }

  .pattern-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .pattern-desc {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin: 0;
  }

  .pattern-fw-badges {
    display: flex;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .fw-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .fw-badge.ts { background: #1e3a5f; color: #60a5fa; }
  .fw-badge.react { background: #164e63; color: #22d3ee; }
  .fw-badge.vue { background: #14532d; color: #4ade80; }
  .fw-badge.svelte { background: #7f1d1d; color: #f87171; }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-size: 1.35rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* README 마크다운 본문 스타일 */
  .markdown-body {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .markdown-body :global(h2) {
    font-size: 1.35rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    color: #f1f5f9;
  }

  .markdown-body :global(h3) {
    font-size: 1.1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #e2e8f0;
  }

  .markdown-body :global(strong) {
    color: var(--color-text);
  }

  .markdown-body :global(ul),
  .markdown-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0.5rem 0;
  }

  .markdown-body :global(li) {
    margin: 0.35rem 0;
  }

  .markdown-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  .markdown-body :global(th) {
    background: var(--color-bg-secondary);
    padding: 0.6rem 1rem;
    text-align: left;
    border: 1px solid var(--color-border);
    font-weight: 600;
    color: #e2e8f0;
  }

  .markdown-body :global(td) {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
  }

  .markdown-body :global(code) {
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: var(--color-bg-code);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .markdown-body :global(pre) {
    background: var(--color-bg-code);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .markdown-body :global(pre code) {
    background: none;
    padding: 0;
  }

  .markdown-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .markdown-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-muted);
  }

  /* Mermaid 다이어그램 */
  .markdown-body :global(.mermaid-container) {
    background: #ffffff;
    border-radius: 10px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    min-height: 80px;
    position: relative;
  }

  /* 렌더링 전: 로딩 상태 */
  .markdown-body :global(.mermaid-container:not(.rendered):not(.fallback))::after {
    content: '다이어그램 로딩 중...';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #94a3b8;
    font-size: 0.85rem;
  }

  .markdown-body :global(.mermaid-container:not(.rendered):not(.fallback) .mermaid) {
    visibility: hidden;
  }

  /* 렌더링 성공 */
  .markdown-body :global(.mermaid-container.rendered .mermaid) {
    visibility: visible;
    display: flex;
    justify-content: center;
  }

  .markdown-body :global(.mermaid-container .mermaid svg) {
    max-width: 100%;
    height: auto;
  }

  /* 렌더링 실패: 코드 텍스트 가시성 확보 */
  .markdown-body :global(.mermaid-container.fallback) {
    background: var(--color-bg-code);
    border: 1px solid var(--color-border);
  }

  .markdown-body :global(.mermaid-container.fallback .mermaid) {
    visibility: visible;
    color: var(--color-text-secondary);
    font-family: 'Fira Code', monospace;
    font-size: 0.8rem;
    white-space: pre;
  }

  /* 코드 블록 */
  .code-block {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .code-block-header {
    padding: 0.5rem 1rem;
    background: var(--color-bg-code);
    border-bottom: 1px solid var(--color-border);
  }

  .code-block-lang {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .code-block :global(pre) {
    margin: 0;
    border: none;
    border-radius: 0;
    max-height: 500px;
    overflow-y: auto;
  }

  /* 네비게이션 */
  .pattern-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: all 0.2s;
    min-width: 160px;
  }

  .nav-link:hover {
    border-color: var(--color-accent);
    background: rgba(56, 189, 248, 0.05);
  }

  .nav-next {
    text-align: right;
    margin-left: auto;
  }

  .nav-dir {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .nav-name {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.9rem;
  }
</style>
